# Local dev + test env. Copy to .env and adjust.
# Compose files load this with `env_file: [.env]`.

# Postgres (used by hosted-gateway via DATABASE_URL)
POSTGRES_USER=hosted
POSTGRES_PASSWORD=hosted
POSTGRES_DB=hosted_gateway
DATABASE_URL=postgresql://hosted:hosted@postgres:5432/hosted_gateway?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Auth
JWT_SECRET_KEY=dev-only-jwt-secret-change-me
GOOGLE_OAUTH_CLIENT_ID=

# Operator wallet — anvil deterministic key (account 0) for local dev/test.
# The bootstrap step in test/setup.ts funds this address with xDAI + xBZZ
# via anvil_setBalance + xBZZ-whale impersonation.
OPERATOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
GNOSIS_RPC_URL=http://anvil:8545

# T4T protocol contracts (Gnosis mainnet — managed by the t4t repo).
# These are valid on the anvil fork because we --fork-url'd Gnosis mainnet.
REGISTRY_ADDRESS=0xf81121AAbc2F7261224BaDd0Ed871711e6D1371E
ESCROW_ADDRESS=0x34Db8E014E71928f17E23eC1272B602582222c9c
XBZZ_ADDRESS=0xdBF3Ea6F5beE45c02255B2c26a16F300502F68da

# Bee — we point at a real running Bee node (bee.ffaerber.duckdns.org) rather
# than spinning up dev-mode Bee in compose. The remote Bee already has real
# postage stamps for PSS routing to mainnet providers.
BEE_API_URL=https://bee.ffaerber.duckdns.org
BEE_POSTAGE_BATCH_ID=
BEE_STAMP_MANAGE=false
BEE_STAMP_LABEL=hosted-gateway-local
BEE_STAMP_TTL_DAYS=30

# Pricing
MARKUP_BPS=2000
WELCOME_XBZZ_WEI=50000000000000000000

# Concurrency
MAX_CONCURRENT_JOBS=200

# Server
HOSTED_GATEWAY_PORT=8080
LOG_LEVEL=debug
